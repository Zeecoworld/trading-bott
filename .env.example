# ============================================================
# ALPACA TRADING CONFIGURATION
# ============================================================
# Get keys from: https://alpaca.markets/
# Use PAPER trading keys for development/testing (STRONGLY recommended)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # Paper trading (safe)
# ALPACA_BASE_URL=https://api.alpaca.markets       # Live trading (REAL MONEY)

# ============================================================
# REPLICATE API (LLM for decisions & sentiment)
# ============================================================
# Get token from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Model to use — uncomment one or set your own from replicate.com/explore
REPLICATE_MODEL=meta/llama-3.3-70b-instruct
# REPLICATE_MODEL=meta/llama-3.1-405b-instruct    # highest quality, slower
# REPLICATE_MODEL=meta/llama-3.1-8b-instruct      # fastest, cheapest
# REPLICATE_MODEL=mistralai/mixtral-8x7b-instruct-v0.1
# REPLICATE_MODEL=deepseek-ai/deepseek-r1          # reasoning model

# ============================================================
# BOT CONFIGURATION
# ============================================================
# Maximum portfolio allocation per single trade (0.0 - 1.0)
MAX_POSITION_SIZE=0.05          # 5% of portfolio per trade

# Maximum total open positions
MAX_OPEN_POSITIONS=10

# Minimum confidence score to execute trade (0.0 - 1.0)
MIN_CONFIDENCE_THRESHOLD=0.65

# Stop-loss percentage below entry price
STOP_LOSS_PCT=0.03              # 3% stop-loss

# Take-profit multiplier (risk-reward ratio)
TAKE_PROFIT_MULTIPLIER=2.5      # 2.5:1 reward-to-risk

# Daily max loss before bot pauses (% of portfolio)
DAILY_MAX_LOSS_PCT=0.05         # 5% daily max drawdown

# ============================================================
# WATCHLIST (comma-separated tickers)
# ============================================================
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,AMD,NFLX,ORCL,CRM,INTC,PYPL,UBER,LYFT,SNAP,BABA,JPM,BAC,GS

# ============================================================
# DASHBOARD
# ============================================================
DASHBOARD_PORT=5000
DASHBOARD_HOST=0.0.0.0
SECRET_KEY=change_this_to_a_strong_random_secret

# ============================================================
# TRADING SCHEDULE (Market hours: 9:30 AM - 4:00 PM ET)
# ============================================================
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=30
MARKET_CLOSE_HOUR=16
MARKET_CLOSE_MINUTE=0

# Scan interval in minutes
SCAN_INTERVAL_MINUTES=5

# ============================================================
# NEWS CONFIGURATION
# ============================================================
NEWS_MAX_AGE_HOURS=24           # Only consider news within X hours
NEWS_FETCH_INTERVAL_MINUTES=10  # How often to fetch new news

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=sqlite:///data/trading_bot.db

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/bot.log
